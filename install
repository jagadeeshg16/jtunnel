#!/usr/bin/env bash
set -e

INSTALL_DIR="/usr/local/bin"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Installing jtunnel..."

# Install aiohttp dependency
if ! python3 -c "import aiohttp" 2>/dev/null; then
    echo "Installing aiohttp..."
    pip3 install aiohttp 2>/dev/null || \
    pip3 install aiohttp --break-system-packages 2>/dev/null || \
    pip3 install aiohttp --user
fi

sudo cp "$SCRIPT_DIR/jtunnel" "$INSTALL_DIR/jtunnel"
sudo chmod 755 "$INSTALL_DIR/jtunnel"
echo "Done! Run: jtunnel 3000"
